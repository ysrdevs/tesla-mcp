# Tesla Fleet API MCP Server Configuration
# Copy to .env and fill in your values

# --- Required: Get these from https://developer.tesla.com ---
TESLA_CLIENT_ID=your_client_id_here
TESLA_CLIENT_SECRET=your_client_secret_here

# --- After OAuth flow (or set manually) ---
TESLA_REFRESH_TOKEN=

# --- Your vehicle ---
TESLA_VIN=your_vin_here

# --- Region: na (North America), eu (Europe), cn (China) ---
TESLA_REGION=na

# --- Token storage path (default: ~/.tesla_tokens.json) ---
# TESLA_TOKEN_FILE=/path/to/tokens.json
